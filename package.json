{
  "name": "judo-score-board",
  "version": "0.0.0",
  "description": "Judo Score Board application",
  "author": "Mariska & Vincent",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "test": "jest",
    "format": "prettier --write src/",
    "electron:dev": "ELECTRON=true vite",
    "electron:build": "ELECTRON=true vite build && electron-builder"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "5.3.3",
    "bootstrap-icons": "^1.11.3",
    "jest": "^29.7.0",
    "vue": "^3.4.27"
  },
  "devDependencies": {
    "@electron/rebuild": "3.7.2",
    "@rushstack/eslint-patch": "^1.8.0",
    "@tsconfig/node20": "^20.1.4",
    "@types/node": "^20.12.7",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/tsconfig": "^0.5.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "9.26.0",
    "eslint-plugin-vue": "^9.23.0",
    "npm-run-all2": "^6.1.2",
    "prettier": "^3.2.5",
    "sass": "^1.75.0",
    "ts-jest": "^29.1.2",
    "tslib": "^2.6.2",
    "typescript": "~5.4.0",
    "vite": "8.0.5",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vite-plugin-vue-devtools": "^7.0.25",
    "vue-tsc": "^2.0.11"
  },
  "build": {
    "appId": "com.judo.scoreboard",
    "productName": "Judo Score Board",
    "publish": [
      {
        "provider": "github"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "win": {
      "icon": "public/logo.ico",
      "target": [
        "portable"
      ]
    },
    "mac": {
      "icon": "public/logo.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "public/logo.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
